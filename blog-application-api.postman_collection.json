  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestName = pm.info.requestName;",
          "const expectedStatusCodes = {",
          "  \"Register Author\": [201],",
          "  \"Register Admin\": [201],",
          "  \"Login User\": [200],",
          "  \"Refresh Token\": [200],",
          "  \"Get All Published Posts\": [200],",
          "  \"Get Most Liked Posts\": [200],",
          "  \"Get My Posts\": [200],",
          "  \"Create Post\": [201],",
          "  \"Get Post by Slug\": [200],",
          "  \"Update Post\": [200],",
          "  \"Delete Post\": [204],",
          "  \"Toggle Post Like\": [200],",
          "  \"Toggle Post Bookmark\": [200],",
          "  \"Get Like Status\": [200],",
          "  \"Get Bookmark Status\": [200],",
          "  \"Get Post Likes\": [200],",
          "  \"Get Posts by Category\": [200],",
          "  \"Get Posts by Tag\": [200],",
          "  \"Get All Categories\": [200],",
          "  \"Get Category by ID\": [200],",
          "  \"Create Category (Admin)\": [201],",
          "  \"Update Category (Admin)\": [200],",
          "  \"Delete Category (Admin)\": [204],",
          "  \"Get All Tags\": [200],",
          "  \"Get Tag by ID\": [200],",
          "  \"Create Tag\": [201],",
          "  \"Delete Tag\": [204],",
          "  \"Add Comment to Post\": [201],",
          "  \"Update Comment\": [200],",
          "  \"Get Post Comments\": [200],",
          "  \"Delete Comment\": [204],",
          "  \"Like Comment\": [200],",
          "  \"Get My Profile\": [200],",
          "  \"Update Profile\": [200],",
          "  \"Change Password\": [200],",
          "  \"Get My Bookmarks\": [200],",
          "  \"Get User by Username\": [200],",
          "  \"Get User Posts\": [200],",
          "  \"Get All Users\": [200],",
          "  \"Get User by ID\": [200],",
          "  \"Delete User\": [204]",
          "};",
          "const expected = expectedStatusCodes[requestName];",
          "if (expected) {",
          "  pm.test(`Status code is one of ${expected.join(', ')}`, function () {",
          "    pm.expect(expected).to.include(pm.response.code);",
          "  });",
          "}",
          "const method = pm.request.method;",
          "const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
          "const hasBody = !!pm.response.text();",
          "if (hasBody && method !== 'HEAD' && requestName !== 'Change Password') {",
          "  pm.test('Response content type is JSON when body is present', function () {",
          "    pm.expect(contentType).to.include('application/json');",
          "  });",
          "}",
          "if ([\"Login User\", \"Refresh Token\"].includes(requestName) && pm.response.code === 200) {",
          "  const jsonData = pm.response.json();",
          "  pm.test('Auth response contains tokens', function () {",
          "    pm.expect(jsonData.accessToken).to.be.a('string').and.not.empty;",
          "    pm.expect(jsonData.refreshToken).to.be.a('string').and.not.empty;",
          "    pm.expect(jsonData.tokenType).to.eql('Bearer');",
          "  });",
          "}",
          "if ([\"Toggle Post Like\", \"Get Like Status\"].includes(requestName) && pm.response.code === 200) {",
          "  const jsonData = pm.response.json();",
          "  pm.test('Like response contains boolean liked field', function () {",
          "    pm.expect(jsonData.liked).to.be.a('boolean');",
          "  });",
          "  if (requestName === 'Toggle Post Like') {",
          "    pm.test('Toggle like response contains numeric likeCount field', function () {",
          "      pm.expect(jsonData.likeCount).to.be.a('number');",
          "    });",
          "  }",
          "}",
          "if ([\"Toggle Post Bookmark\", \"Get Bookmark Status\"].includes(requestName) && pm.response.code === 200) {",
          "  const jsonData = pm.response.json();",
          "  pm.test('Bookmark response contains boolean bookmarked field', function () {",
          "    pm.expect(jsonData.bookmarked).to.be.a('boolean');",
          "  });",
          "  if (requestName === 'Toggle Post Bookmark') {",
          "    pm.test('Toggle bookmark response contains numeric bookmarkCount field', function () {",
          "      pm.expect(jsonData.bookmarkCount).to.be.a('number');",
          "    });",
          "  }",
          "}",
          "if (requestName === 'Like Comment' && pm.response.code === 200) {",
          "  const jsonData = pm.response.json();",
          "  pm.test('Comment like response contains likedByCurrentUser', function () {",
          "    pm.expect(jsonData.likedByCurrentUser).to.be.a('boolean');",
          "  });",
          "}",
          "const pagedRequests = new Set([",
          "  'Get All Published Posts',",
          "  'Get Most Liked Posts',",
          "  'Get My Posts',",
          "  'Get Post Likes',",
          "  'Get Posts by Category',",
          "  'Get Posts by Tag',",
          "  'Get Post Comments',",
          "  'Get My Bookmarks',",
          "  'Get User Posts'",
          "]);",
          "if (pagedRequests.has(requestName) && pm.response.code === 200) {",
          "  const jsonData = pm.response.json();",
          "  pm.test('Paged response exposes content array', function () {",
          "    pm.expect(jsonData).to.have.property('content');",
          "    pm.expect(jsonData.content).to.be.an('array');",
          "  });",
          "}",
          "if ([\"Create Post\", \"Update Post\", \"Get Post by Slug\"].includes(requestName) && pm.response.code >= 200 && pm.response.code < 300) {",
          "  const jsonData = pm.response.json();",
          "  if (jsonData.id) pm.collectionVariables.set('post_id', jsonData.id);",
          "  if (jsonData.slug) pm.collectionVariables.set('post_slug', jsonData.slug);",
          "}",
          "if ([\"Create Category (Admin)\", \"Update Category (Admin)\", \"Get Category by ID\"].includes(requestName) && pm.response.code >= 200 && pm.response.code < 300) {",
          "  const jsonData = pm.response.json();",
          "  if (jsonData.id !== undefined && jsonData.id !== null) pm.collectionVariables.set('category_id', String(jsonData.id));",
          "}",
          "if ([\"Create Tag\", \"Get Tag by ID\"].includes(requestName) && pm.response.code >= 200 && pm.response.code < 300) {",
          "  const jsonData = pm.response.json();",
          "  if (jsonData.id) pm.collectionVariables.set('tag_id', jsonData.id);",
          "}",
          "if ([\"Add Comment to Post\", \"Update Comment\", \"Like Comment\"].includes(requestName) && pm.response.code >= 200 && pm.response.code < 300) {",
          "  const jsonData = pm.response.json();",
          "  if (jsonData.id) pm.collectionVariables.set('comment_id', jsonData.id);",
          "}",
          "if ([\"Login User\", \"Register Author\", \"Register Admin\", \"Get My Profile\", \"Get User by ID\", \"Get User by Username\"].includes(requestName) && hasBody && contentType.includes('application/json')) {",
          "  const jsonData = pm.response.json();",
          "  const user = jsonData.user || jsonData;",
          "  if (user.id) pm.collectionVariables.set('user_id', user.id);",
          "  if (user.username) pm.collectionVariables.set('username', user.username);",
          "}"
        ]
      }
    }
