  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestName = pm.info.requestName;",
          "const hasJsonBody = (() => {",
          "  const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
          "  return pm.response.text() && contentType.includes('application/json');",
          "})();",
          "",
          "if (['Register Author', 'Register Admin', 'Login User', 'Refresh Token'].includes(requestName) && pm.response.code < 300 && hasJsonBody) {",
          "  const json = pm.response.json();",
          "  if (json.accessToken) pm.collectionVariables.set('auth_token', json.accessToken);",
          "  if (json.refreshToken) pm.collectionVariables.set('refresh_token', json.refreshToken);",
          "  if (json.user?.id) pm.collectionVariables.set('user_id', json.user.id);",
          "  if (json.user?.username) pm.collectionVariables.set('username', json.user.username);",
          "}",
          "",
          "if (['Create Category', 'Update Category', 'Get Category by ID'].includes(requestName) && pm.response.code < 300 && hasJsonBody) {",
          "  const json = pm.response.json();",
          "  if (json.id) pm.collectionVariables.set('category_id', json.id);",
          "}",
          "",
          "if (['Create Tag', 'Get Tag by ID'].includes(requestName) && pm.response.code < 300 && hasJsonBody) {",
          "  const json = pm.response.json();",
          "  if (json.id) pm.collectionVariables.set('tag_id', json.id);",
          "}",
          "",
          "if (['Create Post', 'Update Post', 'Get Post by Slug'].includes(requestName) && pm.response.code < 300 && hasJsonBody) {",
          "  const json = pm.response.json();",
          "  if (json.id) pm.collectionVariables.set('post_id', json.id);",
          "  if (json.slug) pm.collectionVariables.set('post_slug', json.slug);",
          "}",
          "",
          "if (['Add Comment', 'Update Comment', 'Like Comment'].includes(requestName) && pm.response.code < 300 && hasJsonBody) {",
          "  const json = pm.response.json();",
          "  if (json.id) pm.collectionVariables.set('comment_id', json.id);",
          "}",
          "",
          "if (['Get My Profile', 'Update Profile', 'Get User by Username', 'Get User by ID'].includes(requestName) && pm.response.code < 300 && hasJsonBody) {",
          "  const json = pm.response.json();",
          "  if (json.id) pm.collectionVariables.set('user_id', json.id);",
          "  if (json.username) pm.collectionVariables.set('username', json.username);",
          "}"
        ]
      }
    }
  ],
